{
  "name": "agentish-sandbox",
  "build": { "dockerfile": "Dockerfile" },

  "features": {
    "ghcr.io/w3cj/devcontainer-features/firewall:0": {
      "verbose": true,
      "claudeCode": true,
      "mistralApi": true,
      "githubDomains": true,
      "githubIps": true,
      "npmRegistry": true,
      "pypi": true,
      "cratesIoRegistry": true,
      "ubuntuPackages": true,
      "hosts": "opencode.ai,api.opencode.ai,my.1password.com,events.1password.com,gitlab.com,codeload.github.com,objects.githubusercontent.com"
    }
  },

  "remoteUser": "vscode",
  "containerUser": "vscode",

  "mounts": [
    "source=${localEnv:HOME}/.config/nvim,target=/home/vscode/.config/nvim,type=bind,readonly",
    "source=${localEnv:HOME}/.config/zsh,target=/home/vscode/.config/zsh,type=bind,readonly",
    "source=${localEnv:HOME}/.config/bat,target=/home/vscode/.config/bat,type=bind,readonly",
    "source=${localEnv:HOME}/.config/git,target=/home/vscode/.config/git,type=bind,readonly",
    "source=${localEnv:HOME}/.config/tmux,target=/home/vscode/.config/tmux,type=bind,readonly",

    "source=${localEnv:HOME}/.config/claude,target=/home/vscode/.config/claude,type=bind",
    "source=${localEnv:HOME}/.config/pi,target=/home/vscode/.config/pi,type=bind",

    "source=${localEnv:HOME}/.config/secrets,target=/home/vscode/.config/secrets,type=bind,readonly",

    "source=${localEnv:HOME}/code/agentish,target=/home/vscode/code/agentish,type=bind,readonly",

    "source=${localEnv:HOME}/.agents,target=/home/vscode/.agents,type=bind,readonly"
  ],

  "containerEnv": {
    "PI_CODING_AGENT_DIR": "/home/vscode/.config/pi/agent",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.config/claude",
    "HOST_HOME": "${localEnv:HOME}",
    "EDITOR": "nvim",
    "PAGER": "bat",
    "BAT_THEME": "Tomorrow-Night"
  },

  "postCreateCommand": "bash /usr/local/bin/post-create.sh"
}
